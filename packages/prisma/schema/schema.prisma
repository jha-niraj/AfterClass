generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
    USER
    ADMIN
}

enum SpaceType {
    LIBRARY
    HOSTEL
    CAFETERIA
    CUSTOM
}

enum PresenceStatus {
    ONLINE
    IDLE
    STUDYING
    OFFLINE
}

enum MessageType {
    TEXT
    SYSTEM
}

model User {
    id             String    @id @default(cuid())
    email          String    @unique
    name           String?
    hashedPassword String?
    emailVerified  DateTime?
    college        String?
    semester       String?
    stream         String?
    image          String?
    address        String?
    role           Role      @default(USER)

    verifyOTP       String?
    verifyOTPExpiry DateTime?
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    spaces       Space[]       @relation("SpaceCreator")
    chatMessages ChatMessage[]
    spaceMembers SpaceMember[]

    @@index([email])
}